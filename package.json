{
  "name": "luggage-ui-new",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "bun run lint && bun run typecheck",
    "dev": "concurrently -k -n web,convex -c auto \"bun run dev:web\" \"bun run dev:convex\"",
    "dev:convex": "convex dev --local",
    "dev:web": "vite",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@tabler/icons-react": "^3.40.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.33.0",
    "framer-motion": "^12.36.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qrcode-pretty": "^3.3.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.12",
    "concurrently": "^9.2.1",
    "eslint": "^9.23.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vite": "^8.0.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  }
}
